{
  "project_name": "Power BI Report Designer",
  "version": "1.0.0",
  "type": "SaaS Design Tool",
  "theme_strategy": {
    "name": "The Architect's Blueprint",
    "mode": "Hybrid (Dark Sidebar / Light Canvas)",
    "emotional_tone": "Precision, Clarity, Efficiency",
    "inspiration": "Figma, Canva, Linear"
  },
  "typography": {
    "font_family": {
      "headings": "Manrope, sans-serif",
      "body": "Inter, sans-serif",
      "code": "JetBrains Mono, monospace"
    },
    "weights": {
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700
    },
    "scale": {
      "xs": "0.75rem",
      "sm": "0.875rem",
      "base": "1rem",
      "lg": "1.125rem",
      "xl": "1.25rem",
      "2xl": "1.5rem",
      "3xl": "1.875rem"
    }
  },
  "colors": {
    "palette": {
      "primary": "#4F46E5",
      "primary_hover": "#4338CA",
      "secondary": "#3B82F6",
      "sidebar_bg": "#1e1e2e",
      "sidebar_border": "#2d2d3b",
      "sidebar_text": "#e2e2e2",
      "sidebar_text_muted": "#a1a1aa",
      "canvas_bg": "#f3f4f6",
      "canvas_paper": "#ffffff",
      "border": "#e5e7eb",
      "text_main": "#111827",
      "text_muted": "#6b7280",
      "power_bi_gold": "#F2C811"
    },
    "chart_colors": {
      "bar": "#2563EB",
      "line": "#10B981",
      "pie": "#8B5CF6",
      "donut": "#EC4899",
      "area": "#14B8A6"
    }
  },
  "layout": {
    "grid_system": "Bento Grid (Sidebar | Canvas | Properties)",
    "spacing": {
      "sidebar_width": "280px",
      "properties_width": "300px",
      "toolbar_height": "60px"
    },
    "z_indices": {
      "canvas": 0,
      "overlays": 10,
      "panels": 20,
      "modals": 50,
      "toasts": 100
    }
  },
  "components": {
    "button": {
      "radius": "0.375rem",
      "variants": ["default", "outline", "ghost", "secondary"],
      "default_class": "font-medium transition-all active:scale-95"
    },
    "input": {
      "radius": "0.375rem",
      "bg": "bg-transparent",
      "border": "border-input"
    },
    "card": {
      "radius": "0.5rem",
      "shadow": "shadow-sm",
      "border": "border-border"
    }
  },
  "visual_enhancers": {
    "glassmorphism": "backdrop-blur-md bg-white/80 border border-white/20",
    "shadows": {
      "soft": "0 2px 8px rgba(0, 0, 0, 0.05)",
      "float": "0 10px 30px rgba(0, 0, 0, 0.1)"
    },
    "gradients": {
      "subtle_fade": "linear-gradient(to bottom, rgba(255,255,255,0) 0%, rgba(255,255,255,1) 100%)"
    }
  },
  "image_assets": {
    "presets": [
      {
        "name": "Geometric Tech",
        "url": "https://images.unsplash.com/photo-1704122545404-56107e7e7adf?q=85&w=1920&auto=format&fit=crop",
        "category": "texture"
      },
      {
        "name": "Clean Studio",
        "url": "https://images.unsplash.com/photo-1629724024952-bada03d4e392?q=85&w=1920&auto=format&fit=crop",
        "category": "texture"
      }
    ]
  },
  "tech_stack_instructions": {
    "canvas_engine": "react-konva",
    "state_management": "zustand",
    "icons": "lucide-react",
    "styling": "tailwind-merge + clsx"
  },
  "pbi_visuals": [
    "card", "bar_chart", "line_chart", "pie_chart", "donut_chart",
    "table", "matrix", "slicer", "map", "image", "text_box", "shape"
  ],
  "implementation_steps": [
    "1. Setup Zustand store (useStore) for canvas state (elements, selection, history).",
    "2. Implement Layout Shell: Sidebar (Left), Toolbar (Top), Properties (Right), Canvas Area (Center).",
    "3. Build Canvas Component (Konva Stage/Layer). Implement Zoom/Pan.",
    "4. Create 'Draggable Item' logic: Sidebar -> Canvas (Drop).",
    "5. Implement Transformer (Resize/Rotate) logic in Konva.",
    "6. Build Properties Panel: Update selected element attributes (x, y, color, text).",
    "7. Add 'Export' function: Convert Stage to DataURL (PNG) or SVG string.",
    "8. Implement 'Background' logic: Solid color, Gradient, or Image."
  ],
  "universal_guidelines": [
    "Use 'sonner' for all notifications (Saved, Exported, Undo).",
    "Ensure 'data-testid' is present on all interactive elements.",
    "Dark Mode is ONLY for the Sidebar/Toolbar. The Canvas area is Light (unless user changes background).",
    "Use 'react-colorful' for color pickers.",
    "Do NOT use native alerts/confirms. Use custom Dialogs (Shadcn)."
  ]
}